        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "output_ext": ".tif"
      },
      {
        "key": "parallel_workers",
        "label": "并发进程数",
        "type": "integer",
        "required": true,
        "placeholder": "例如 2",
        "default": 2,
        "help_text": "系统调度参数，只用于控制同时运行几个子任务，不会写入单个 exe 的 config.json。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "control_only": true
      }
    ],
    "tool_type": "aerosol",
    "parallel": {
      "mode": "auto",
      "input_key": "",
      "output_key": "",
      "file_patterns": "*.tif;*.tiff;*.nc;*.hdf;*.h5",
      "output_suffix": ".tif"
