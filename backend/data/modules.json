        "required": true
      },
      {
        "key": "outpath",
        "label": "最终输出目录",
        "type": "dir_path",
        "required": true
      }
    ],
    "tags": [
      "h8",
      "cloud",
      "cth",
      "云类型",
      "云反演"
    ],
    "enabled": true,
    "entry": "CM_CTH.exe",
    "runtime": "cpp_native",
    "tool_type": "cloud",
    "parallel": {
      "mode": "auto",
      "input_key": "",
      "output_key": "",
      "file_patterns": "*.tif;*.tiff;*.nc;*.hdf;*.h5",
      "output_suffix": ".tif"
    }
  },
