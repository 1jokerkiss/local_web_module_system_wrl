[
  {
    "id": "h8aod",
    "name": "H8 AOD 反演",
    "description": "H8 AOD 本地原生模块。用户按目录输入 B01、B03、B06、SOLAR，系统后端自动按文件名时次匹配并拆分为多个单文件 job，再按并发进程数调用 AOD_AHI.exe 执行。",
    "runtime": "native",
    "entry": "AOD_AHI.exe",
    "executable": "backend/installed_modules/h8aod/AOD_AHI.exe",
    "working_dir": "backend/installed_modules/h8aod",
    "config_mode": "json_file",
    "dependency_dirs": [
      "deps"
    ],
    "command_template": [
      "{executable}",
      "{config_path}"
    ],
    "tags": [
      "h8",
      "aod",
      "remote-sensing",
      "batch"
    ],
    "enabled": true,
    "inputs": [
      {
        "key": "B01_file",
        "label": "B01 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 B01 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 B01 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B01",
        "match_mode": "timeslot"
      },
      {
        "key": "B03_file",
        "label": "B03 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 B03 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 B03 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B03",
        "match_mode": "timeslot"
      },
      {
        "key": "B06_file",
        "label": "B06 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 B06 文件所在目录",
