        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none"
      },
      {
        "key": "output",
        "label": "输出目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择输出目录",
        "default": "",
