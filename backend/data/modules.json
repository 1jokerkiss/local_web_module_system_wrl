        "label": "B01 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 B01 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 B01 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B01",
        "match_mode": "timeslot"
      },
      {
        "key": "B03_file",
        "label": "B03 文件夹",
        "type": "dir_path",
        "required": true,
