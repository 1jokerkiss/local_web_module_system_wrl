[
  {
    "id": "h8aod",
    "name": "H8 AOD 反演",
    "description": "H8 AOD 本地原生模块。用户按目录输入 B01、B03、B06、SOLAR，系统后端自动按文件名时次匹配并拆分为多个单文件 job，再按并发进程数调用 AOD_AHI.exe 执行。",
    "runtime": "native",
    "entry": "AOD_AHI.exe",
    "executable": "backend/installed_modules/h8aod/AOD_AHI.exe",
    "working_dir": "backend/installed_modules/h8aod",
    "config_mode": "json_file",
    "dependency_dirs": [
      "deps"
    ],
    "command_template": [
      "{executable}",
      "{config_path}"
    ],
    "tags": [
      "h8",
      "aod",
      "remote-sensing",
      "batch"
    ],
    "enabled": true,
    "inputs": [
      {
        "key": "B01_file",
        "label": "B01 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 B01 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 B01 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B01",
        "match_mode": "timeslot"
      },
      {
        "key": "B03_file",
        "label": "B03 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 B03 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 B03 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B03",
        "match_mode": "timeslot"
      },
      {
        "key": "B06_file",
        "label": "B06 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 B06 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 B06 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B06",
        "match_mode": "timeslot"
      },
      {
        "key": "SOLAR_file",
        "label": "SOLAR 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 SOLAR 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 SOLAR 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "SOLAR",
        "match_mode": "timeslot"
      },
      {
        "key": "GEO1_file",
        "label": "GEO1 文件路径",
        "type": "file_path",
        "required": true,
        "placeholder": "",
        "default": "resources/lon_lat_az_zen_1000_73_19_140_54.tif",
        "help_text": "管理员固定输入，用户界面隐藏。该文件需要随模块一起放在 resources 目录下。",
        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none"
      },
      {
        "key": "al_igbp",
        "label": "IGBP 文件路径",
        "type": "file_path",
        "required": true,
        "placeholder": "",
        "default": "resources/h8_aod_igbp.tif",
        "help_text": "管理员固定输入，用户界面隐藏。该文件需要随模块一起放在 resources 目录下。",
        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none"
      },
      {
        "key": "al_lut",
        "label": "LUT 文件路径",
        "type": "file_path",
        "required": true,
        "placeholder": "",
        "default": "resources/h8_aod_lut.dat",
        "help_text": "管理员固定输入，用户界面隐藏。该文件需要随模块一起放在 resources 目录下。",
        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none"
      },
      {
        "key": "al_dem",
        "label": "DEM 文件路径",
        "type": "file_path",
        "required": true,
        "placeholder": "",
        "default": "resources/dem_1000_73_19_140_54.tif",
        "help_text": "管理员固定输入，用户界面隐藏。该文件需要随模块一起放在 resources 目录下。",
        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none"
      },
      {
        "key": "output",
        "label": "输出目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择输出目录",
        "default": "",
        "help_text": "输出目录可以为空目录。系统会为每个匹配 job 自动生成输出 tif 文件名。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "output_ext": ".tif"
      },
      {
        "key": "parallel_workers",
        "label": "并发进程数",
        "type": "integer",
        "required": true,
        "placeholder": "例如 2",
        "default": 2,
        "help_text": "系统调度参数，只用于控制同时运行几个子任务，不会写入单个 exe 的 config.json。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "control_only": true
      }
    ],
    "tool_type": "aerosol",
    "parallel": {
      "mode": "batch_group",
      "file_patterns": "*.tif;*.tiff;*.img;*.hdf;*.HDF;*.h5;*.H5;*.nc;*.NC;*.dat;*.DAT",
      "output_suffix": ".tif",
      "output_naming": "source_stem"
    }
  },
  {
    "id": "parasol_aod",
    "name": "PARASOL AOD 反演",
    "description": "PARASOL AOD 本地原生模块。用户选择 PARASOL 输入文件目录和输出目录，管理员固定配置 XML、LUT 和 IGBP 资源。",
    "runtime": "native",
    "entry": "ParasolAOD.exe",
    "executable": "backend/installed_modules/parasol_aod/ParasolAOD.exe",
    "working_dir": "backend/installed_modules/parasol_aod",
    "config_mode": "none",
    "dependency_dirs": [
      "deps"
    ],
    "command_template": [
      "{executable}",
      "{input_file}",
      "{output_dir}",
      "{config_xml}"
    ],
    "parallel": {
      "mode": "folder_chunks",
      "input_key": "input_file",
      "output_key": "output_dir",
      "file_patterns": "*JD*;*JD_*;*JD-*;*.hdf;*.HDF;*.dat;*.DAT;*.nc;*.NC",
      "output_suffix": ".tif",
      "files_per_job": 2
    },
    "tags": [
      "parasol",
      "aod",
      "remote-sensing",
      "native"
    ],
    "enabled": true,
    "inputs": [
      {
        "key": "input_file",
        "label": "PARASOL 输入文件目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 PARASOL Level-1 输入文件所在目录",
        "default": "",
        "help_text": "选择一个目录，平台会把目录中的输入文件拆成多个 job 并行运行。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "parasol",
        "match_mode": "each_file"
      },
      {
        "key": "output_dir",
        "label": "输出目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择输出目录",
        "default": "",
        "help_text": "程序会在该目录下生成输出文件。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "output_ext": ".tif"
      },
      {
        "key": "config_xml",
        "label": "PARASOL 配置 XML",
        "type": "file_path",
        "required": true,
        "placeholder": "",
        "default": "resources/ConfigXMLFile.xml",
        "help_text": "管理员固定输入，用户界面隐藏。XML 中配置 LUT 和 IGBP 文件路径。",
        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none"
      }
    ],
    "tool_type": "aerosol"
  },
  {
    "id": "H8_CLOUD_TYPE_EXE",
    "name": "葵花8号云类型反演",
    "tool_type": "cloud",
    "description": "葵花8号云类型反演可执行模块，运行时读取 config.json，输入 NC 文件目录，输出云检测中间结果和最终 CARE_24CP 结果。",
    "runtime": "executable",
    "executable": "backend/installed_modules/H8_CLOUD_TYPE_EXE/CM_CTH.exe",
    "working_dir": "backend/installed_modules/H8_CLOUD_TYPE_EXE",
    "config_mode": "json_file",
    "command_template": [
      "{executable}",
      "{config_path}"
    ],
    "inputs": [
      {
        "key": "file",
        "label": "Input Folder",
        "type": "dir_path",
        "required": true,
        "placeholder": "Select NC input folder",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "input"
      },
      {
        "key": "cm_files",
        "label": "Cloud Mask Folder",
        "type": "dir_path",
        "required": true,
        "placeholder": "Select cloud mask output folder",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "output"
      },
      {
        "key": "outpath",
        "label": "Output Folder",
        "type": "dir_path",
        "required": true,
        "placeholder": "Select final output folder",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "output"
      }
    ],
    "parallel": {
      "mode": "folder_chunks",
      "input_key": "file",
      "output_key": "outpath",
      "file_patterns": "*.nc;*.NC",
      "output_suffix": ".tif",
      "files_per_job": 2
    },
    "dependency_dirs": [
      "_internal",
      "deps"
    ],
    "auto_collect_deps": false,
    "tags": [
      "h8",
      "cloud",
      "cth",
      "executable"
    ],
    "enabled": true
  },
