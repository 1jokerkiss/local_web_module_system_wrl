        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "output_ext": ".tif"
      },
      {
        "key": "parallel_workers",
        "label": "并发进程数",
        "type": "integer",
        "required": true,
        "placeholder": "例如 2",
        "default": 2,
        "help_text": "系统调度参数，只用于控制同时运行几个子任务，不会写入单个 exe 的 config.json。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "control_only": true
      }
    ],
    "tool_type": "aerosol",
    "parallel": {
      "mode": "batch_group",
      "input_key": "",
      "output_key": "",
      "file_patterns": "*.tif;*.tiff;*.img;*.hdf;*.HDF;*.h5;*.H5;*.nc;*.NC;*.dat;*.DAT",
      "output_suffix": ".tif",
      "files_per_job": 1,
      "chunk_multiplier": 1
    },
    "category": "aerosol"
  },
  {
    "id": "CTH_FY",
    "name": "FY CTH 反演",
    "tool_type": "cloud",
    "category": "cloud",
    "description": "FY4 cloud top height retrieval executable module. It reads HDF files from the input folder and writes CTH GeoTIFF results to the output folder.",
    "runtime": "executable",
    "executable": "backend/installed_modules/CTH_FY/CTH_FY.exe",
    "working_dir": "backend/installed_modules/CTH_FY",
    "config_mode": "json_file",
    "command_template": [
      "{executable}",
      "{config_path}"
    ],
    "inputs": [
      {
        "key": "fy4_path",
        "label": "FY4 HDF Input Folder",
        "type": "dir_path",
        "required": true,
        "placeholder": "Select FY4 HDF input folder",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "input"
      },
      {
        "key": "out_path",
        "label": "Output Folder",
        "type": "dir_path",
        "required": true,
        "placeholder": "Select output folder",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "output"
      }
    ],
    "parallel": {
      "mode": "folder_chunks",
      "input_key": "fy4_path",
      "output_key": "out_path",
      "file_patterns": "*.hdf;*.HDF",
      "output_suffix": ".tif",
      "files_per_job": 2,
      "chunk_multiplier": 1
    },
    "dependency_dirs": [
      "_internal",
      "deps"
    ],
    "auto_collect_deps": false,
    "tags": [
      "FY4",
      "CTH",
      "cloud",
      "executable"
    ],
    "enabled": true
  },
