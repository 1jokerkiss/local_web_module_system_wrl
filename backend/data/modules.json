[
  {
    "id": "cloud_type",
    "name": "云类型反演",
    "description": "基于葵花8的云类型反演模块（CM_CTH.exe）",
    "executable": "backend/installed_modules/cth/CM_CTH.exe",
    "working_dir": "backend/installed_modules/cth",
    "config_mode": "json",
    "command_template": [
      "{executable}",
      "{config_json}"
    ],
    "inputs": [
      {
        "key": "file",
        "label": "NC文件目录",
        "type": "dir_path",
        "required": true,
        "io_role": "input",
        "data_role": "input",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none"
      },
      {
        "key": "cm_files",
        "label": "CM文件目录",
        "type": "dir_path",
        "required": true,
        "io_role": "input",
        "data_role": "input",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none"
      },
      {
        "key": "outpath",
        "label": "输出目录",
        "type": "dir_path",
        "required": true,
        "io_role": "output",
        "data_role": "output",
        "output_ext": ".tif",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none"
      }
    ],
    "tags": [
      "cth",
      "cloud",
      "cloud_type",
      "云类型",
      "h8"
    ],
    "tool_type": "cloud",
    "enabled": true,
    "parallel": {
      "mode": "module_internal",
      "input_key": "",
      "output_key": "",
      "file_patterns": "*.tif;*.tiff;*.nc;*.nc4;*.hdf;*.h5",
      "output_suffix": ".tif"
    }
  },
  {
    "id": "parasol_aod",
    "name": "PARASOL AOD 反演",
    "description": "PARASOL AOD 本地原生模块。用户选择 PARASOL 输入文件目录和输出目录，管理员固定配置 XML、LUT 和 IGBP 资源。",
    "runtime": "native",
    "entry": "ParasolAOD.exe",
    "executable": "D:\\local_web_module_system_wrl\\backend\\installed_modules\\parasol_aod\\ParasolAOD.exe",
    "working_dir": "D:\\local_web_module_system_wrl\\backend\\installed_modules\\parasol_aod",
    "config_mode": "none",
    "dependency_dirs": [
      "deps"
    ],
    "command_template": [
      "{executable}",
      "{input_file}",
      "{output_dir}",
      "{config_xml}"
    ],
    "parallel": {
      "mode": "auto",
      "input_key": "",
      "output_key": "",
      "file_patterns": "*",
      "output_suffix": ".tif"
    },
    "tags": [
      "parasol",
      "aod",
      "remote-sensing",
      "native"
    ],
    "enabled": true,
    "inputs": [
      {
        "key": "input_file",
        "label": "PARASOL 输入文件目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 PARASOL Level-1 输入文件所在目录",
        "default": "",
        "help_text": "选择一个目录，平台会把目录中的输入文件拆成多个 job 并行运行。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "parasol",
        "match_mode": "each_file",
        "io_role": "input",
        "data_role": "input",
        "file_patterns": "*",
        "batch_allow_no_extension": true,
        "batch_allow_all_files": true
      },
      {
        "key": "output_dir",
        "label": "输出目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择输出目录",
        "default": "",
        "help_text": "程序会在该目录下生成输出文件。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "output_ext": ".tif",
        "io_role": "output",
        "data_role": "output",
        "output_naming": "source_stem"
      },
      {
        "key": "config_xml",
        "label": "PARASOL 配置 XML",
        "type": "file_path",
        "required": true,
        "placeholder": "",
        "default": "resources/ConfigXMLFile.xml",
        "help_text": "管理员固定输入，用户界面隐藏。XML 中配置 LUT 和 IGBP 文件路径。",
        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none",
        "io_role": "input",
        "data_role": "input"
      }
    ],
    "tool_type": "aerosol"
  },
  {
    "id": "FY",
