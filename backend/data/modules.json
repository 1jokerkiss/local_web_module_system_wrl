        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B06",
        "match_mode": "timeslot"
      },
      {
        "key": "SOLAR_file",
        "label": "SOLAR 文件夹",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 SOLAR 文件所在目录",
        "default": "",
        "help_text": "批量输入目录。目录中放 SOLAR 数据文件，系统会按文件名时次自动匹配生成 job。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "SOLAR",
        "match_mode": "timeslot"
      },
      {
        "key": "GEO1_file",
        "label": "GEO1 文件路径",
        "type": "file_path",
