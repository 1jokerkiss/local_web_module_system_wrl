    "category": "cloud",
    "description": "基于葵花8的云类型反演模块（CM_CTH.exe）",
    "executable": "backend/installed_modules/cth/CM_CTH.exe",
    "working_dir": "backend/installed_modules/cth",
    "config_mode": "json",
    "command_template": [
      "{executable}",
      "{config_json}"
    ],
    "inputs": [
      {
        "key": "file",
        "label": "NC文件目录",
        "type": "dir_path",
        "required": true
      },
      {
        "key": "cm_files",
        "label": "CM文件目录",
        "type": "dir_path",
        "required": true
      },
      {
        "key": "outpath",
        "label": "输出目录",
        "type": "dir_path",
        "required": true
      }
    ],
    "tags": [
      "cth",
      "cloud",
      "cloud_type",
      "云类型",
      "h8"
    ],
    "enabled": true
  },
  {
