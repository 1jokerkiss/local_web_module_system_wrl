[
  {
    "id": "h8aod",
    "name": "H8 AOD 反演",
    "description": "H8 AOD 本地原生模块。用户按目录输入 B01、B03、B06、SOLAR。",
    "runtime": "native",
    "entry": "AOD_AHI.exe",
