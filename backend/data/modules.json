        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "B03",
        "match_mode": "timeslot"
      },
      {
        "key": "B06_file",
        "label": "B06 文件夹",
        "type": "dir_path",
        "required": true,
