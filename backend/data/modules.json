    "enabled": true,
    "inputs": [
      {
        "key": "input_file",
        "label": "PARASOL 输入文件目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择 PARASOL Level-1 输入文件所在目录",
        "default": "",
        "help_text": "选择一个目录，平台会把目录中的输入文件拆成多个 job 并行运行。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "parasol",
        "match_mode": "each_file"
      },
      {
        "key": "output_dir",
        "label": "输出目录",
        "type": "dir_path",
        "required": true,
        "placeholder": "请选择输出目录",
        "default": "",
        "help_text": "程序会在该目录下生成输出文件。",
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "batch_role": "",
        "match_mode": "none",
        "output_ext": ".tif"
      },
      {
        "key": "config_xml",
        "label": "PARASOL 配置 XML",
        "type": "file_path",
        "required": true,
        "placeholder": "",
        "default": "resources/ConfigXMLFile.xml",
        "help_text": "管理员固定输入，用户界面隐藏。XML 中配置 LUT 和 IGBP 文件路径。",
        "visible_to_user": false,
        "admin_fixed": true,
        "path_mode": "relative_to_module",
        "batch_role": "",
        "match_mode": "none"
      }
    ],
    "tool_type": "气溶胶反演"
  },
